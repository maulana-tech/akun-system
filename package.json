{
  "name": "akun-system-desktop",
  "version": "1.0.0",
  "author": "Maulana Tech <contact@maulana.tech>",
  "homepage": "https://siakunt.app",
  "description": "SIAKUNT - Sistem Informasi Akuntansi Terintegrasi",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:electron\"",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm run dev",
    "start:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:frontend && npm run build:all",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -wm"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.akuntansi.system",
    "productName": "SIAKUNT",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "asar": true,
    "icon": "build/icon.png",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    }
  }
}
